# Copy this file to server/.env and fill in real values before running the server.

# Any long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Port the Express server listens on
PORT=4000

# Set to "production" when deploying (enables secure cookies, serves client/dist)
NODE_ENV=development

# Only used in development, so the Vite dev server (5173) can call the API with cookies
CLIENT_ORIGIN=http://localhost:5173

# MariaDB / MySQL connection — see README "Database setup" for how to create
# this database and user
DB_HOST=localhost
DB_PORT=3306
DB_USER=taxify
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=taxify

# SMTP settings used to send one-time login codes (see "OTP login" in README).
# If left unset, the OTP feature will fail to send emails — users who enable
# it won't be able to log in until SMTP is configured.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change-me
SMTP_PASSWORD=change-me
SMTP_FROM="Taxify <no-reply@example.com>"
