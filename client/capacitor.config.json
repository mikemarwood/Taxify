{
  "appId": "com.mikesapphub.taxify",
  "appName": "Taxify",
  "webDir": "dist",
  "server": {
    "url": "https://taxify.mikesapphub.com",
    "androidScheme": "https",
    "cleartext": false
  },
  "android": {
    "backgroundColor": "#0a0f18"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1600,
      "launchAutoHide": true,
      "launchFadeOutDuration": 400,
      "backgroundColor": "#0a0f18",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
  }
}
